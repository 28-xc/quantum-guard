# 复制本文件为 .env 并填入真实值。.env 已被 gitignore，不会提交。
# 发验证码的邮箱（QQ）：SMTP 登录账号与发件人地址
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ邮箱@qq.com
SMTP_PASSWORD=你的QQ邮箱授权码
SMTP_FROM=

# 可选：若 SMTP_FROM 留空则使用 SMTP_USER 作为发件人
# JWT 与 CORS（生产环境必填）
# JWT_SECRET=your_jwt_secret
# CORS_ORIGINS=https://your-frontend.example.com
